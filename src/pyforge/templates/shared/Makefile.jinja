.DEFAULT_GOAL := help

.PHONY: help install test lint format run clean

help:
	@echo "Available targets:"
	@echo "  install  Install the project in editable mode with dev dependencies"
	@echo "  test     Run the test suite"
	@echo "  lint     Run Ruff checks"
	@echo "  format   Format the codebase with Ruff"
	@echo "  run      Start the generated application"
	@echo "  clean    Remove local build and cache artifacts"

install:
	pip install -e ".[dev]"

test:
	pytest

lint:
	ruff check .

format:
	ruff format .

run:
{%- if template == 'fastapi' %}
	uvicorn src.{{ project_name }}.main:app --reload
{%- elif template == 'flask' %}
	FLASK_APP=src/{{ project_name }}/app.py flask run
{%- elif template == 'cli' %}
	{{ project_name }}
{%- else %}
	python -m {{ project_name }}
{%- endif %}

clean:
	find . -type d -name __pycache__ -exec rm -rf {} +
	find . -type d -name .pytest_cache -exec rm -rf {} +
	find . -type d -name .ruff_cache -exec rm -rf {} +
	rm -rf build/ dist/ *.egg-info/
